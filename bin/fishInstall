#!/bin/sh
#
# fishInstall: Installs Fish Shell configuration files.
#
# usage: fishInstall [ --install | --check | --remove | --clean | --nuke ]
#
#        where --install: installs fish config into ~/.config/fish
#              --check:   checks what was installed
#              --remove:  removes all files which were installed
#              --clean:   same as above, deletes emptied directories
#              --nuke:    removes everything fish related
#
# shellcheck shell=sh
# shellcheck disable=SC3043

scriptName=fishInstall
df_home="${DOTFILES_GIT_REPO:=~/devel/dotfiles}"/home

if test -d "$df_home"
then
    cd "$df_home" || {
        printf '\n%s: Error - failed to cd into "%s"\n\n' "$scriptName" "$df_home"
        exit 1
    }
else
    printf '\n%s: Error - df_home = "%s" does not exist as a directory!\n\n' "$scriptName" "$df_home"
    exit 1
fi

. ../bin/sourced/parse_cmdline_and_source_functions.sh

config_files='
    completions/pp.fish
    completions/ve.fish
    conf.d/00-initial-environment.fish
    conf.d/10-dotfiles.fish
    conf.d/50-abbrs.fish
    conf.d/51-colors.fish
    conf.d/70-rustup.fish
    functions/ax.fish
    functions/cu.fish
    functions/dotf.fish
    functions/fdg.fish
    functions/ff.fish
    functions/fishcolors.fish
    functions/fm.fish
    functions/fish_greeting.fish
    functions/fish_mode_prompt.fish
    functions/fish_prompt.fish
    functions/fish_title.fish
    functions/iv.fish
    functions/jdk_version.fish
    functions/la.fish
    functions/ldir.fish
    functions/ldot.fish
    functions/lf.fish
    functions/lh.fish
    functions/ll.fish
    functions/ls.fish
    functions/mc.fish
    functions/nsort.fish
    functions/ocp.fish
    functions/run.fish
    functions/pp.fish
    functions/pv.fish
    functions/rc.fish
    functions/tm.fish
    functions/ve.fish
    functions/Wget.fish
    functions/WgetM.fish
    functions/b2b.fish
    functions/b2d.fish
    functions/b2h.fish
    functions/b2o.fish
    functions/d2b.fish
    functions/d2d.fish
    functions/d2h.fish
    functions/d2o.fish
    functions/h2b.fish
    functions/h2d.fish
    functions/h2h.fish
    functions/h2o.fish
    functions/o2b.fish
    functions/o2d.fish
    functions/o2h.fish
    functions/o2o.fish
    config.fish
    fish_plugins
'

remove_items="
    $XDG_CONFIG_HOME/fish/conf.d/00-ensure-or-redo-init-env.fish
    $XDG_CONFIG_HOME/conf.d/dotfiles.fish
    $XDG_CONFIG_HOME/conf.d/abbrs.fish
    $XDG_CONFIG_HOME/conf.d/colors.fish
    $XDG_CONFIG_HOME/conf.d/rustup.fish
    $XDG_CONFIG_HOME/fish/functions/align2.fish
    $XDG_CONFIG_HOME/fish/functions/zip_it.fish
    $XDG_CONFIG_HOME/fish/functions/junk.fish
    $XDG_CONFIG_HOME/fish/functions/ve_old.fish
"

dirs_to_create=""

items_to_clean="
    $XDG_CONFIG_HOME/fish
"

items_to_nuke="
    $XDG_CONFIG_HOME/fish
    $XDG_DATA_HOME/fish
    $XDG_CACHE_HOME/fish
"

## Perform ACTION

case "$DF_ACTION" in
    install|check|remove)
        # Install Fish config files
        process_files "$XDG_CONFIG_HOME/fish" "$config_files" config/fish 0644 "$df_home"
        chmod 0755 "$XDG_CONFIG_HOME/fish"

        # Remove/report no longer needed files and directories
        remove_items "$remove_items"
 
        # Create/report missing directories
        ensure_dirs "$dirs_to_create"
 
        # Ensure fish plugins are installed, assuming fish is.
        if command -v fish >/dev/null 2>&1 && test "$DF_ACTION" = install
        then
            install_plugins=yes
            if ! test -f "$XDG_CONFIG_HOME"/fish/functions/fisher.fish
            then
                if ! fish -c df_install_fisher
                then
                    printf '%s: Failed to install fisher\n' "$scriptName" >&2
                    install_plugins=no
                fi
            fi
            if test "$install_plugins" = yes
            then
                if fish -c 'fisher update'
                then
                    printf '%s: Failed to install fish plugins\n' "$scriptName"
                fi
            fi
        fi
        ;;
    clean)
       remove_items "$items_to_clean"
       ;;
    nuke)
       remove_items "$items_to_clean $items_to_nuke"
       ;;
esac
