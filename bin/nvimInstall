#!/bin/sh
#
# Installs Neovim configuration files into the
# user's $HOME directory.
#
# usage: nvimInstall [ --install | --check | --remove | --clean | --nuke ]
#
#        where --install: installs nvim config into ~/.config/nvim
#              --check:   checks what was installed
#              --remove:  removes all files which were installed
#              --clean:   same as above, but also lazy.nvim installation
#              --nuke:    removes everything nvim related

# shellcheck shell=sh

export SCRIPT_NAME=nvimInstall
export DF_ACTION=install

export DOTFILES_GIT_REPO="${DOTFILES_GIT_REPO:=$HOME/devel/dotfiles}"
cd "$DOTFILES_GIT_REPO/home" || {
    printf '%s: failed to cd into %s\n' "$SCRIPT_NAME" "$DOTFILES_GIT_REPO/home" >&2
    exit 1
}

umask 0022

. ../bin/sourced/parse_cmdline.sh
. ../bin/sourced/functions.sh
. ../bin/sourced/configure_xdg_dirs.sh

dot_config_files='
    after/ftplugin/c.lua
    after/ftplugin/cpp.lua
    after/ftplugin/csv.lua
    after/ftplugin/fish.lua
    after/ftplugin/go.lua
    after/ftplugin/haskell.lua
    after/ftplugin/help.lua
    after/ftplugin/html.lua
    after/ftplugin/lua.lua
    after/ftplugin/markdown.lua
    after/ftplugin/ocaml.lua
    after/ftplugin/python.lua
    after/ftplugin/rust.lua
    after/ftplugin/sbt.lua
    after/ftplugin/scala.lua
    after/ftplugin/sh.lua
    after/ftplugin/toml.lua
    after/ftplugin/text.lua
    after/ftplugin/tsv.lua
    after/ftplugin/zig.lua
    init.lua
    lsp/ast_grep.lua
    lsp/bashls.lua
    lsp/cssls.lua
    lsp/cssmodules_ls.lua
    lsp/css_variables.lua
    lsp/html.lua
    lsp/lua_ls.lua
    lsp/marksman.lua
    lsp/ruff.lua
    lsp/tombi.lua
    lsp/zls.lua
    lsp/zuban.lua
    lua/config/autocmds.lua
    lua/config/diagnostics.lua
    lua/config/globals.lua
    lua/config/keymaps.lua
    lua/config/lsp.lua
    lua/config/options.lua
    lua/config/tooling.lua
    lua/config/treesitter.lua
    lua/core/lazy.lua
    lua/lib/functional.lua
    lua/lib/mason.lua
    lua/lib/scroll.lua
    lua/lib/text.lua
    lua/plugins/debug.lua
    lua/plugins/development.lua
    lua/plugins/infrastructure.lua
    lua/plugins/lsp_plugins.lua
    lua/plugins/tooling.lua
    lua/plugins/visual_appearance.lua
    lua/plugins/visual_editing.lua
    spell/en.utf-8.add
'

toml_files='
    stylua.toml
'

remove_items="
    $HOME/.vimrc
    $XDG_CONFIG_HOME/nvim/lua/config/tools.lua
    $XDG_CONFIG_HOME/nvim/lua/config/autocmds_text.lua
    $XDG_CONFIG_HOME/nvim/lua/config/usercmds_lsp.lua
    $XDG_CONFIG_HOME/nvim/lua/plugins/tool_install/
    $XDG_CONFIG_HOME/nvim/lua/plugins/appearance/
    $XDG_CONFIG_HOME/nvim/lua/plugins/debug/
    $XDG_CONFIG_HOME/nvim/lua/plugins/coding/
    $XDG_CONFIG_HOME/nvim/lua/plugins/infrastructure/
    $XDG_CONFIG_HOME/nvim/lua/plugins/appearance.lua
    $XDG_CONFIG_HOME/nvim/lua/plugins/completions.lua
    $XDG_CONFIG_HOME/nvim/lua/plugins/coding.lua
    $XDG_CONFIG_HOME/nvim/lsp/css_modules_ls.lua
"

dirs_to_create=""

# Pre ACTION Checks and Tasks

# Determine if spellfile will need to be recompiled after install.
spell_file="$XDG_CONFIG_HOME/nvim/spell/en.utf-8.add"
if which nvim > /dev/null 2>&1
then
    if test ! -e "$spell_file"
    then
        compile_spell_file=yes
    elif diff -q "$spell_file" config/nvim/spell/en.utf-8.add 2>&1
    then
        compile_spell_file=no
    else
        compile_spell_file=yes
    fi
fi

# Perform ACTION

case "$DF_ACTION" in
    install|check|remove)
        # Install/Check Neovim files & nvim related TOML files
        process_files "$XDG_CONFIG_HOME/nvim" "
            $dot_config_files
            $toml_files
        " config/nvim 0644
        chmod 0755 "$XDG_CONFIG_HOME/nvim"
 
        # Remove/report no longer needed files and directories
        remove_items "$remove_items"
 
        # Create/report missing directories
        ensure_dirs "$dirs_to_create"
        ;;
    clean)
        remove_item "$XDG_CONFIG_HOME/nvim"
        remove_item "$XDG_DATA_HOME/nvim/lazy"
        remove_item "$XDG_STATE_HOME/nvim/lazy"
        ;;
    nuke)
        remove_item "$XDG_CONFIG_HOME/nvim"
        remove_item "$XDG_DATA_HOME/nvim"
        remove_item "$XDG_STATE_HOME/nvim"
        remove_item "$XDG_CACHE_HOME/nvim"
        ;;
esac

# Post ACTION Tasks

test "$DF_ACTION" = install && {
    # Recompiled spell file if necessary
    if test "$compile_spell_file" = yes
    then
        sf="${spell_file##*/}"
        sf_dir="${spell_file%/*}"
        (
            if cd "$sf_dir"
            then
                nvim -u NONE --cmd "mkspell!$sf" --cmd 'qa!'
            fi
        )
    fi
}

test "$DF_ACTION" = check && {
    # Indicate whether the spellfile will be recompiled on next install
    if test "$compile_spell_file" = yes
    then
        printf 'nvimInstall: Spellfile "%s" will be\n' "$spell_file"
        printf '             recompiled on the next install.\n\n'
    fi
}
