#!/bin/sh
#
# dfInstall: POSIX shell scripts to install an entire Linux desktop
#            environment into the user's $HOME directory.
#
# usage: dfInstall [ --install | --check | --remove | --clean | --nuke ]
#
#        where --install: installs dotfiles into $HOME
#              --check:   checks what was installed
#              --remove:  generally removes what was installed
#              --clean:   like above but tries to conservatively clean things up
#              --nuke:    like above but deletes even manually installed things
#
# shellcheck shell=dash

scriptName=dfInstall
df_home="${DOTFILES_GIT_REPO:=$HOME/devel/dotfiles}"/home

if test -d "$df_home"
then
    cd "$df_home" || {
        printf '\n%s: Error - failed to cd into "%s"\n\n' "$scriptName" "$df_home"
        exit 1
    }
else
    printf '\n%s: Error - df_home = "%s" does not exist as a directory!\n\n' "$scriptName" "$df_home"
    exit 1
fi

DF_ACTION=''

. ../bin/sourced/parse_cmdline_and_source_functions.sh

# Install dotfiles in parallel
(. ../bin/nvimInstall) &
(. ../bin/fishInstall) &
(. ../bin/develInstall) &

wait
