#!/bin/sh
#
# dfInstall: POSIX shell scripts to install an entire Linux desktop
#            environment into the user's $HOME directory.
#
# usage: dfInstall [ --install | --check | --remove | --clean | --nuke ]
#
#        where --install: installs dotfiles into $HOME
#              --check:   checks what was installed
#              --remove:  generally removes what was installed
#              --clean:   like above but tries to conservatively clean things up
#              --nuke:    like above but deletes even manually installed things

# shellcheck shell=sh

export DOTFILES_GIT_REPO="${DOTFILES_GIT_REPO:=$HOME/devel/dotfiles}"
cd "$DOTFILES_GIT_REPO/home" || {
    printf 'dfInstall: failed to cd into %s\n' "$DOTFILES_GIT_REPO/home" >&2
    exit 1
}

# Install in parallel - problematic when scripts converted to fish.

../bin/fishInstall  "$@"
../bin/bashInstall  "$@"
../bin/nvimInstall  "$@"
../bin/develInstall "$@"
